{
  "printWidth": 120,
  "trailingComma": "es5",
  "tabWidth": 4,
  "useTabs": false,
  "overrides": [
    {
      "files": ["*.json", "*.yml", ".prettierrc"],
      "options": {
        "tabWidth": 2
      }
    },
    {
      "files": [".eslintrc"],
      "options": {
        "parser": "json",
        "tabWidth": 2
      }
    }
  ],
  "semi": true,
  "singleQuote": true
}
