{
	"compilerOptions": {
		"target": "es2024",
		"module": "nodenext",
		"strict": true,
		"preserveConstEnums": true,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"resolveJsonModule": true,
		"outDir": "dist",
		"allowImportingTsExtensions": true,
		"noEmit": true,
		"types": [
			"node"
		]
	},
	"include": [
		"lib/**/*",
		"test/**/*",
		"*.mjs"
	],
	"exclude": [
		"node_modules",
		"dist",
	]
}
