{
	"name": "@opencover/eslint-config-opencover",
	"version": "2.0.5",
	"description": "ESLint Typescript shareable config for OpenCover's coding style.",
	"keywords": [
		"eslint",
		"eslintrc",
		"eslintconfig",
		"config",
		"styleguide",
		"react",
		"node"
	],
	"license": "MIT",
	"author": {
		"name": "Thanos Diamantidis",
		"email": "thanos@opencover.com",
		"url": "https://opencover.com"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/GeltFinance/eslint-config-opencover.git"
	},
	"type": "module",
	"main": "index.mjs",
	"files": [
		"index.mjs",
		"with-react.mjs",
		"lib"
	],
	"scripts": {
		"test": "ava -v",
		"prepare": "husky",
		"lint": "eslint --max-warnings=0 . && prettier --check .",
		"format": "eslint --fix . && prettier --write ."
	},
	"devDependencies": {
		"@types/node": "^24.10.0",
		"ava": "^6.4.1",
		"eslint": "^9.39.1",
		"husky": "^9.1.7",
		"tsx": "^4.20.6",
		"typescript": "^5.9.3"
	},
	"peerDependencies": {
		"eslint": "^9.0.0",
		"typescript": "^5.0.0"
	},
	"dependencies": {
		"@eslint/compat": "^1.4.1",
		"@eslint/js": "^9.39.1",
		"eslint-config-prettier": "^10.1.8",
		"eslint-import-resolver-typescript": "^4.4.4",
		"eslint-plugin-import": "^2.32.0",
		"eslint-plugin-jsx-a11y": "^6.10.2",
		"eslint-plugin-prettier": "^5.5.4",
		"eslint-plugin-react": "^7.37.5",
		"eslint-plugin-react-hooks": "^7.0.1",
		"eslint-plugin-unicorn": "^62.0.0",
		"lint-staged": "^16.2.6",
		"prettier": "^3.6.2",
		"typescript-eslint": "^8.46.3"
	},
	"engines": {
		"node": ">=22.20.0"
	},
	"lint-staged": {
		"**/*.{ts,tsx,js,jsx}": [
			"eslint --cache --max-warnings=0 --fix",
			"prettier --cache --write"
		],
		"*.{json,yml}": "prettier --cache --write",
		".{prettierrc,eslintrc}": "prettier --cache --write"
	},
	"ava": {
		"extensions": {
			"ts": "module"
		},
		"nodeArguments": [
			"--import",
			"tsx"
		]
	}
}
