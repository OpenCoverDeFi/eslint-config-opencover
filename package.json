{
  "name": "@opencover/eslint-config",
  "version": "3.0.0",
  "type": "module",
  "private": true,
  "main": "dist/index.js",
  "description": "ESLint Typescript shareable config for OpenCover's coding style.",
  "author": {
    "name": "OpenCover",
    "email": "team@opencover.com",
    "url": "https://opencover.com"
  },
  "keywords": [
    "eslint",
    "eslintconfig",
    "config",
    "styleguide",
    "react",
    "node"
  ],
  "license": "UNLICENSED",
  "repository": {
    "type": "git",
    "url": "https://github.com/OpenCoverDeFi/eslint-config-opencover.git"
  },
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts",
    "dist/**/*.d.ts.map"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json && tsc-alias -p tsconfig.build.json",
    "format": "pnpm build && eslint --fix . && prettier --write .",
    "lint": "pnpm build && eslint --max-warnings=0 . && prettier --check .",
    "typecheck": "tsc --noEmit",
    "changeset": "changeset",
    "changeset:version": "changeset version",
    "changeset:release": "pnpm build && changeset publish",
    "prepare": "husky",
    "test": "pnpm build && vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@eslint/core": "^1.0.0",
    "@eslint/js": "^9.39.2",
    "@stylistic/eslint-plugin": "^5.5.0",
    "@vitest/eslint-plugin": "^1.6.5",
    "eslint-config-flat-gitignore": "^2.1.0",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-unicorn": "^62.0.0",
    "tsc-alias": "^1.8.16",
    "typescript-eslint": "^8.52.0"
  },
  "peerDependencies": {
    "eslint": "^9.39.1",
    "eslint-plugin-react": "^7",
    "eslint-plugin-react-hooks": "^7",
    "typescript": "^5.9.3"
  },
  "peerDependenciesMeta": {
    "eslint-plugin-react": {
      "optional": true
    },
    "eslint-plugin-react-hooks": {
      "optional": true
    }
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.5.2",
    "@changesets/cli": "^2.29.8",
    "@types/node": "^22.19.3",
    "@vitest/coverage-v8": "^4.0.0",
    "eslint": "^9.39.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "husky": "^9.1.7",
    "knip": "^5.80.2",
    "lint-staged": "^16.2.6",
    "prettier": "^3.7.4",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.16"
  },
  "engines": {
    "node": ">=22",
    "pnpm": ">=10"
  },
  "lint-staged": {
    "**/*.{ts,tsx,js,jsx,mjs}": [
      "tsx ./node_modules/eslint/bin/eslint.js --cache --max-warnings=0 --fix --no-warn-ignored",
      "prettier --cache --write"
    ],
    "*.{json,yml}": "prettier --cache --write",
    ".prettierrc": "prettier --cache --write"
  },
  "knip": {
    "ignoreDependencies": [
      "eslint-plugin-react",
      "eslint-plugin-react-hooks"
    ]
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public"
  },
  "packageManager": "pnpm@10.28.0"
}
