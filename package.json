{
	"name": "@opencover/eslint-config-opencover",
	"version": "2.0.5",
	"description": "ESLint Typescript shareable config for OpenCover's coding style.",
	"keywords": [
		"eslint",
		"eslintrc",
		"eslintconfig",
		"config",
		"styleguide",
		"react",
		"node"
	],
	"license": "MIT",
	"author": {
		"name": "OpenCover",
		"email": "team@opencover.com",
		"url": "https://opencover.com"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/GeltFinance/eslint-config-opencover.git"
	},
	"type": "module",
	"main": "dist/default.js",
	"types": "dist/default.d.ts",
	"exports": {
		".": {
			"types": "./dist/default.d.ts",
			"default": "./dist/default.js"
		},
		"./with-react": {
			"types": "./dist/with-react.d.ts",
			"default": "./dist/with-react.js"
		},
		"./plugin": {
			"types": "./dist/plugin.d.ts",
			"default": "./dist/plugin.js"
		}
	},
	"files": [
		"dist/**/*.js",
		"dist/**/*.d.ts",
		"dist/**/*.d.ts.map"
	],
	"scripts": {
		"test": "vitest run",
		"test:ui": "vitest --ui",
		"test:coverage": "vitest run --coverage",
		"build": "tsc -p tsconfig.build.json && tsc-alias -p tsconfig.build.json",
		"postinstall": "tsc -p tsconfig.build.json && tsc-alias -p tsconfig.build.json",
		"prepare": "husky",
		"lint": "eslint --max-warnings=0 . && prettier --check .",
		"format": "eslint --fix . && prettier --write ."
	},
	"dependencies": {
		"@eslint/js": "^9.39.1",
		"@typescript-eslint/utils": "^8.46.4",
		"@vitest/eslint-plugin": "^1.4.2",
		"eslint": "^9.39.1",
		"eslint-config-prettier": "^10.1.8",
		"eslint-import-resolver-typescript": "^4.4.4",
		"eslint-plugin-import": "^2.32.0",
		"eslint-plugin-prettier": "^5.5.4",
		"eslint-plugin-react": "^7.37.5",
		"eslint-plugin-react-hooks": "^7.0.1",
		"eslint-plugin-unicorn": "^62.0.0",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.46.4"
	},
	"devDependencies": {
		"@types/node": "^24.10.0",
		"@vitest/coverage-v8": "^3.2.4",
		"@vitest/ui": "^3.2.4",
		"dedent": "^1.7.0",
		"husky": "^9.1.7",
		"jiti": "^2.6.1",
		"lint-staged": "^16.2.6",
		"prettier": "^3.6.2",
		"tsc-alias": "^1.8.16",
		"tsx": "^4.20.6",
		"vitest": "^3.2.4"
	},
	"engines": {
		"node": ">=22.20.0"
	},
	"lint-staged": {
		"**/*.{ts,tsx,js,jsx}": [
			"eslint --cache --max-warnings=0 --fix",
			"prettier --cache --write"
		],
		"*.{json,yml}": "prettier --cache --write",
		".{prettierrc,eslintrc}": "prettier --cache --write"
	}
}
