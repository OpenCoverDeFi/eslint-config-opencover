{
  "name": "@opencover/eslint-config-opencover",
  "version": "3.0.0",
  "description": "ESLint Typescript shareable config for OpenCover's coding style.",
  "keywords": [
    "eslint",
    "eslintconfig",
    "config",
    "styleguide",
    "react",
    "node"
  ],
  "license": "MIT",
  "author": {
    "name": "OpenCover",
    "email": "team@opencover.com",
    "url": "https://opencover.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/GeltFinance/eslint-config-opencover.git"
  },
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./react": {
      "types": "./dist/react.d.ts",
      "default": "./dist/react.js"
    }
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts",
    "dist/**/*.d.ts.map"
  ],
  "scripts": {
    "test": "vitest run",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "build": "tsc -p tsconfig.build.json && tsc-alias -p tsconfig.build.json",
    "prepack": "yarn build",
    "prepare": "husky",
    "eslint": "node --loader ts-node/esm --no-warnings ./node_modules/.bin/eslint --max-warnings=0 .",
    "lint": "node --loader ts-node/esm --no-warnings ./node_modules/.bin/eslint --max-warnings=0 . && prettier --check .",
    "format": "node --loader ts-node/esm --no-warnings ./node_modules/.bin/eslint --fix . && prettier --write ."
  },
  "dependencies": {
    "@eslint/js": "^9.39.1",
    "@typescript-eslint/utils": "^8.47.0",
    "@vitest/eslint-plugin": "^1.4.2",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-unicorn": "^62.0.0",
    "tsutils": "^3.21.0",
    "typescript-eslint": "^8.47.0"
  },
  "peerDependencies": {
    "eslint": "^9.39.1",
    "typescript": "^5.9.3"
  },
  "devDependencies": {
    "@stylistic/eslint-plugin": "^5.5.0",
    "@types/node": "^24.10.0",
    "@vitest/coverage-v8": "^3.2.4",
    "@vitest/ui": "^3.2.4",
    "dedent": "^1.7.0",
    "eslint": "^9.39.1",
    "eslint-import-resolver-typescript": "^4.4.4",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.6",
    "prettier": "^3.6.2",
    "ts-node": "^10.9.2",
    "tsc-alias": "^1.8.16",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=22.20.0"
  },
  "lint-staged": {
    "**/*.{ts,tsx,js,jsx}": [
      "node --loader ts-node/esm --no-warnings ./node_modules/.bin/eslint --cache --max-warnings=0 --fix",
      "prettier --cache --write"
    ],
    "*.{json,yml}": "prettier --cache --write",
    ".{prettierrc,eslintrc}": "prettier --cache --write"
  }
}
