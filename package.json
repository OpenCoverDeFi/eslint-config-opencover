{
  "name": "@OpenCoverDeFi/eslint",
  "version": "3.0.0",
  "type": "module",
  "private": true,
  "main": "dist/index.js",
  "description": "ESLint Typescript shareable config for OpenCover's coding style.",
  "author": {
    "name": "OpenCover",
    "email": "team@opencover.com",
    "url": "https://opencover.com"
  },
  "keywords": [
    "eslint",
    "eslintconfig",
    "config",
    "styleguide",
    "react",
    "node"
  ],
  "license": "UNLICENSED",
  "repository": {
    "type": "git",
    "url": "https://github.com/OpenCoverDeFi/eslint-config-opencover.git"
  },
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./react": {
      "types": "./dist/react.d.ts",
      "default": "./dist/react.js"
    }
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts",
    "dist/**/*.d.ts.map"
  ],
  "scripts": {
    "prepare": "husky && pnpm build",
    "build": "tsc -p tsconfig.build.json && tsc-alias -p tsconfig.build.json",
    "lint": "tsx ./node_modules/.bin/eslint --max-warnings=0 . && prettier --check .",
    "typecheck": "tsc --noEmit",
    "format": "tsx ./node_modules/.bin/eslint --fix . && prettier --write .",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@eslint/js": "^9.39.2",
    "@stylistic/eslint-plugin": "^5.5.0",
    "eslint-import-resolver-typescript": "^4.4.4",
    "@typescript-eslint/utils": "^8.52.0",
    "@vitest/eslint-plugin": "^1.6.5",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-unicorn": "^62.0.0",
    "tsutils": "^3.21.0",
    "typescript-eslint": "^8.52.0",
    "tsc-alias": "^1.8.16"
  },
  "peerDependencies": {
    "eslint": "^9.39.1",
    "typescript": "^5.9.3"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@vitest/coverage-v8": "^4.0.0",
    "dedent": "^1.7.1",
    "eslint": "^9.39.2",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.6",
    "prettier": "^3.7.4",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.0"
  },
  "engines": {
    "node": ">=22.20.0"
  },
  "lint-staged": {
    "**/*.{ts,tsx,js,jsx,mjs}": [
      "tsx ./node_modules/.bin/eslint --cache --max-warnings=0 --fix",
      "prettier --cache --write"
    ],
    "*.{json,yml}": "prettier --cache --write",
    ".{prettierrc,eslintrc}": "prettier --cache --write"
  }
}
