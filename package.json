{
  "name": "eslint-config-opencover",
  "version": "2.0.5",
  "type": "module",
  "description": "ESLint Typescript shareable config for OpenCover's coding style.",
  "author": {
    "name": "OpenCover",
    "email": "team@opencover.com",
    "url": "https://opencover.com"
  },
  "keywords": [
    "eslint",
    "eslintconfig",
    "config",
    "styleguide",
    "node"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/OpenCoverDeFi/eslint-config-opencover.git"
  },
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts",
    "dist/**/*.d.ts.map"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json && tsc-alias -p tsconfig.build.json",
    "format": "pnpm build && eslint --fix . && prettier --write .",
    "lint": "pnpm build && eslint --max-warnings=0 . && prettier --check .",
    "typecheck": "tsc --noEmit",
    "changeset": "changeset",
    "changeset:version": "changeset version",
    "changeset:release": "pnpm build && changeset publish",
    "prepare": "husky",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@eslint/js": "^10.0.1",
    "@stylistic/eslint-plugin": "^5.8.0",
    "@vitest/eslint-plugin": "^1.6.9",
    "eslint-config-flat-gitignore": "^2.1.0",
    "eslint-plugin-import-x": "^4.16.1",
    "eslint-plugin-unicorn": "^62.0.0",
    "typescript-eslint": "^8.56.0"
  },
  "peerDependencies": {
    "eslint": "^10.0.1",
    "typescript": "^5.9.3"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.5.2",
    "@changesets/cli": "^2.29.8",
    "@types/node": "^22.19.11",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^10.0.1",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "knip": "^5.84.0",
    "lint-staged": "^16.2.7",
    "prettier": "^3.8.1",
    "tsc-alias": "^1.8.16",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=22",
    "pnpm": ">=10"
  },
  "lint-staged": {
    "**/*.{ts,tsx,js,jsx,mjs}": [
      "eslint --cache --max-warnings=0 --fix",
      "prettier --cache --write"
    ],
    "*.{json,yml,yaml,md}": "prettier --cache --write",
    ".prettierrc": "prettier --cache --write"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public"
  },
  "packageManager": "pnpm@10.28.0"
}
